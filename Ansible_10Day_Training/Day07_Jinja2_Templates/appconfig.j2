# {{ app_name }} configuration

app_name = {{ app_name }}
app_env  = {{ app_env | default('production') }}
version  = {{ version }}
debug    = {{ debug | lower }}

# Database
db_host  = {{ db_host }}
db_port  = {{ db_port }}
db_user  = {{ db_user | lower }}
db_password = {{ db_password }}

# inline conditional
mode = {{ 'development' if app_env == 'dev' else 'production' }}
